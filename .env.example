# =============================================================================
# Variables de entorno del CRM Pro
# =============================================================================
# Copiá este archivo como `.env` y completá los valores reales.
# El `.env` está ignorado por git — nunca lo subas al repo.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (requerido)
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL="aqui tu url"
VITE_SUPABASE_ANON_KEY="aqui tu anon key"

# -----------------------------------------------------------------------------
# SuperAPI · OAuth 2.0 (opcional — feature flag OFF por defecto)
# -----------------------------------------------------------------------------
# Estas variables habilitan el nuevo flujo OAuth con SuperAPI (sustituye/convive
# con el flujo manual de copiar/pegar API tokens). Mientras Morna no entregue
# las credenciales reales (client_id), dejar VITE_SUPERAPI_OAUTH_ENABLED=false.
#
# Ver SUPERAPI_OAUTH_SETUP.md para la guía completa de activación.

# Feature flag — pone a `true` solo cuando todas las demás estén configuradas
VITE_SUPERAPI_OAUTH_ENABLED=false

# URL del consent screen (cambiar a v5 cuando lance la nueva versión)
VITE_SUPERAPI_OAUTH_AUTHORIZE_URL=https://v4.iasuperapi.com/oauth/authorize

# client_id público de la OAuthApp registrada (entregado por Morna)
VITE_SUPERAPI_OAUTH_CLIENT_ID=

# Si se deja vacío, se usa `${window.location.origin}/superapi/callback`
# automáticamente. Solo poner valor explícito si necesitás overridearlo
# (ej. en preview deployments).
VITE_SUPERAPI_OAUTH_REDIRECT_URI=

# -----------------------------------------------------------------------------
# Los siguientes secrets NO van en este archivo — van en Supabase Dashboard
# como secrets de Edge Functions (Settings → Edge Functions → Secrets):
#
#   SUPERAPI_BASE_URL              (ej. https://v4.iasuperapi.com)
#   SUPERAPI_OAUTH_TOKEN_URL       (ej. https://v4.iasuperapi.com/oauth/token)
#   SUPERAPI_OAUTH_CLIENT_ID       (mismo valor que VITE_SUPERAPI_OAUTH_CLIENT_ID)
#   SUPERAPI_OAUTH_CLIENT_SECRET   (privado — entregado por Morna)
#   SUPERAPI_OAUTH_SIGNING_SECRET  (privado — entregado por Morna, para HMAC de webhooks)
#
# -----------------------------------------------------------------------------
